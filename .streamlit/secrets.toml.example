# Streamlit secrets 템플릿
#
# 로컬 개발: 이 파일을 .streamlit/secrets.toml 로 복사 후 키 입력 (또는 .env 사용)
# Streamlit Cloud 배포: share.streamlit.io의 앱 설정 → "Secrets" 메뉴에 같은 형식으로 입력
#
# ⚠️ 절대 secrets.toml은 GitHub에 커밋하지 마세요 (.gitignore에 등록됨).

DART_API_KEY = "여기에_DART_OPEN_API_키"
GEMINI_API_KEY = "여기에_GEMINI_API_키"

# 선택: 비밀번호 보호 (외부 공개 시 권장)
# APP_PASSWORD = "원하는_비밀번호"
