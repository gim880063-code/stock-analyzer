# Streamlit secrets 템플릿
#
# 로컬 개발: 이 파일을 .streamlit/secrets.toml 로 복사 후 키 입력 (또는 .env 사용)
# Streamlit Cloud 배포: share.streamlit.io의 앱 설정 → "Secrets" 메뉴에 같은 형식으로 입력
#
# ⚠️ 절대 secrets.toml은 GitHub에 커밋하지 마세요 (.gitignore에 등록됨).

DART_API_KEY = "여기에_DART_OPEN_API_키"
GEMINI_API_KEY = "여기에_GEMINI_API_키"

# 선택: 비밀번호 보호 (외부 공개 시 권장)
# APP_PASSWORD = "원하는_비밀번호"

# 선택: GitHub Gist 영구 저장소 — Streamlit Cloud 재배포 후에도 포트폴리오·점수
# 히스토리·즐겨찾기·워치리스트가 유지되도록 함. 미설정 시 로컬 파일만 사용.
#
# 셋업:
#   1. https://github.com/settings/tokens/new — gist 권한만 체크해서 PAT 생성
#   2. https://gist.github.com — 비공개 Gist 생성, 빈 portfolio.json/score_history.json/
#      favorites.json/watchlist.json 파일 추가
#   3. Gist URL의 마지막 ID 부분을 복사
#
# GITHUB_PAT = "ghp_xxxxxxxxxxxxxxxx"
# GIST_ID = "abc123def456789..."
