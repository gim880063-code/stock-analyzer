# 비밀 키 — 절대 커밋 금지
.env
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.venv*/

# 캐시·로컬 데이터 (디렉토리 자체는 보존, 파일만 제외)
# data/ 가 아니라 data/* 로 써야 아래 negation(!)이 동작함
data/*
# 단, DART corp_code 매핑은 공개 데이터이고 Streamlit Cloud 배포 시 부트스트랩
# 다운로드 실패하면 가치/재무/성장/공시 점수가 전부 None이 되는 치명적 의존성이라
# 예외적으로 git에 포함 (~87KB, 변경 빈도 낮음).
!data/corp_codes.json
# DART 재무 캐시도 부트스트랩 — Streamlit Cloud → DART 네트워크가 막혔을 때
# Gist 캐시 채워질 때까지 옛 데이터로라도 점수 계산 가능하게.
!data/dart_financials_cache.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# 임시 디버그 스크립트
test_*.py
scratch_*.py
!tests/
!tests/test_*.py
